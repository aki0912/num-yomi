{
  "name": "num-yomi",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli/num-yomi.js"
  },
  "bin": {
    "num-yomi": "dist/cli/num-yomi.js",
    "replace-num-yomi": "dist/cli/replace-num-yomi.js"
  },
  "scripts": {
    "generate:rules": "python3 scripts/generate_rules_artifacts.py",
    "prebuild": "pnpm generate:rules",
    "build": "tsc",
    "num-yomi": "node dist/cli/num-yomi.js",
    "replace-num-yomi": "node dist/cli/replace-num-yomi.js",
    "start": "pnpm num-yomi",
    "pretest": "pnpm build",
    "test": "node scripts/run-cases.js",
    "bench:node": "node bench/bench_node.mjs --cases test/cases.json --iterations 20000",
    "bench:node:call": "node bench/bench_node_call.mjs --cases test/cases.json --iterations 20000",
    "bench:node:replace:call": "node bench/bench_node_replace_call.mjs --cases test/replace_cases.json --iterations 20000",
    "bench:python": "python3 python_impl/num_yomi.py bench --cases test/cases.json --iterations 20000",
    "bench:python:call": "python3 bench/bench_python_call.py --cases test/cases.json --iterations 20000",
    "bench:python:replace:call": "python3 bench/bench_python_replace_call.py --cases test/replace_cases.json --iterations 20000",
    "bench:rust": "cargo run --quiet --release --manifest-path rust_impl/Cargo.toml --bin num-yomi-rust -- bench --cases test/cases.json --iterations 20000",
    "bench:rust:call": "cargo run --quiet --release --manifest-path rust_impl/Cargo.toml --bin bench_call -- --cases test/cases.json --iterations 20000",
    "bench:rust:replace:call": "cargo run --quiet --release --manifest-path rust_impl/Cargo.toml --bin bench_replace_call -- --cases test/replace_cases.json --iterations 20000",
    "bench:compare": "python3 scripts/compare_benchmarks.py --call-style --cases test/cases.json --iterations 20000",
    "bench:compare:replace": "python3 scripts/compare_benchmarks.py --call-style --replace-style --cases test/replace_cases.json --iterations 20000"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  }
}
