{
  "name": "japanese-number-reading",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli/yomi.js"
  },
  "bin": {
    "yomi": "dist/cli/yomi.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/yomi.js",
    "test": "node scripts/run-cases.js",
    "bench:node": "node bench/bench_node.mjs --cases test/cases.json --iterations 20000",
    "bench:node:call": "node bench/bench_node_call.mjs --cases test/cases.json --iterations 20000",
    "bench:python": "python3 python_impl/yomi.py bench --cases test/cases.json --iterations 20000",
    "bench:python:call": "python3 bench/bench_python_call.py --cases test/cases.json --iterations 20000",
    "bench:rust": "cargo run --quiet --release --manifest-path rust_impl/Cargo.toml -- bench --cases test/cases.json --iterations 20000",
    "bench:rust:call": "cargo run --quiet --release --manifest-path rust_impl/Cargo.toml --bin bench_call -- --cases test/cases.json --iterations 20000",
    "bench:compare": "python3 scripts/compare_benchmarks.py --cases test/cases.json --iterations 20000",
    "bench:compare:call": "python3 scripts/compare_benchmarks.py --call-style --cases test/cases.json --iterations 20000"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  }
}
