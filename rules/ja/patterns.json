{
  "patterns": {
    "h_row_3forms": {
      "type": "tail_form_selector",
      "rules": [
        {
          "whenTailIn": ["いち", "ろく", "はち", "じゅう", "ひゃく", "びゃく", "ぴゃく"],
          "rewriteTail": {
            "いち": "いっ",
            "ろく": "ろっ",
            "はち": "はっ",
            "じゅう": "じゅっ",
            "ひゃく": "ひゃっ",
            "びゃく": "びゃっ",
            "ぴゃく": "ぴゃっ"
          },
          "useForm": "p"
        },
        {
          "whenTailIn": ["さん", "せん", "ぜん", "まん"],
          "useForm": "b"
        }
      ],
      "defaultForm": "h"
    }
  }
}
